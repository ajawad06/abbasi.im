# Copy this file to .env.local and fill in real values (.env.local is git-ignored).
# On Vercel, set these same variables in Project Settings → Environment Variables.

# Contact form (Web3Forms) — https://web3forms.com
VITE_WEB3FORMS_KEY=your-web3forms-access-key

# Blog comments (Supabase) — https://supabase.com  (see SUPABASE_SETUP.md)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
